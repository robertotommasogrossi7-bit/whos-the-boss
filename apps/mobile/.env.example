# Supabase (mobile) — copia in apps/mobile/.env (gitignored) coi valori reali.
# Le var EXPO_PUBLIC_* sono inlineate da Metro nel bundle (la anon key e' pubblica
# per design: i dati sono protetti dalle RLS). Stesso progetto Supabase del web.
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...la-tua-anon-key-pubblica
